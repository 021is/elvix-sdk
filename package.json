{
  "name": "@elvix.is/sdk",
  "version": "0.7.13",
  "description": "Official elvix SDK. Drop-in React components, server helpers, and an MCP server so AI coding agents integrate elvix on the first try.",
  "license": "MIT",
  "homepage": "https://elvix.is",
  "author": {
    "name": "edvone",
    "url": "https://edvone.dev"
  },
  "funding": "https://edvone.dev/book",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/021is/elvix-sdk.git"
  },
  "bugs": "https://github.com/021is/elvix-sdk/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "elvix": "./dist/cli/index.js",
    "elvix-mcp": "./dist/mcp/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./styles.css": {
      "types": "./dist/styles.css.d.ts",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.ts src/server.ts src/types.ts src/mcp/index.ts src/mcp/bin.ts src/cli/index.ts src/cli/doctor.ts --format esm --dts --clean --external react --external react/jsx-runtime --external next && bun run build:css && node scripts/postbuild.mjs",
    "build:css": "tailwindcss --input src/styles/sdk.css --output dist/styles.css --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "next": ">=15"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@021.is/spine-i18n": "^0.4.3",
    "@modelcontextprotocol/sdk": "1.29.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "react-easy-crop": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.15",
    "tailwindcss": "^4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "elvix",
    "authentication",
    "auth",
    "passkey",
    "otp",
    "google-oauth",
    "react",
    "nextjs",
    "mcp",
    "model-context-protocol",
    "ai-agents"
  ]
}
